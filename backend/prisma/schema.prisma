datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Neon URL
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Example habit table relation (add later)
  // habits        Habit[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
